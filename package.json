{
  "name": "agentic",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Trusted execution control plane for governed goals, approvals, automations, memories, documents, and integrations.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardwongly/agentic.git"
  },
  "bugs": {
    "url": "https://github.com/leonardwongly/agentic/issues"
  },
  "keywords": [
    "agentic",
    "automation",
    "governance",
    "workflow",
    "typescript",
    "nextjs"
  ],
  "type": "module",
  "engines": {
    "node": ">=20 <27"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @agentic/web",
    "build": "npm run build -w @agentic/web && npm run build -w @agentic/worker",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:check-migrations": "tsx scripts/check-migration-discipline.ts",
    "db:status": "tsx scripts/db-status.ts",
    "production:bootstrap:check": "tsx scripts/production-bootstrap-check.ts",
    "governance:simulate": "tsx scripts/governance-simulation-suite.ts",
    "security:audit-runtime": "tsx scripts/runtime-vulnerability-gate.ts",
    "security:sbom": "tsx scripts/generate-sbom.ts",
    "ci:validate-provenance": "tsx scripts/validate-github-actions-provenance.ts",
    "ci:issue-theme-gates": "tsx scripts/issue-theme-gates.ts",
    "ci:local": "tsx scripts/local-ci.ts",
    "security:collect-evidence": "tsx scripts/collect-compliance-evidence.ts",
    "compliance:validate-registry": "tsx scripts/validate-compliance-registry.ts",
    "lint": "tsx scripts/check-workspace-lint.ts",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "format:check": "tsx scripts/check-format.ts",
    "release:check-context": "tsx scripts/check-release-context.ts",
    "release:closeout:evidence": "tsx scripts/release-closeout-evidence.ts",
    "setup:check": "tsx scripts/check-first-run.ts",
    "hygiene:repo": "tsx scripts/repo-hygiene-report.ts",
    "test": "vitest run",
    "test:eval:model": "tsx scripts/model-eval.ts",
    "test:repository:parity": "vitest run tests/repository-parity.test.ts",
    "test:security:regression": "tsx scripts/security-regression-suite.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy:staging:plan": "tsx scripts/staging-execution-plan.ts",
    "deploy:staging:provider": "tsx scripts/staging-provider-deploy.ts",
    "deploy:ingress:check": "tsx scripts/stable-ingress-config.ts",
    "github:app-sync:preflight": "tsx scripts/github-app-sync-live-preflight.ts",
    "github:app-sync:preflight:collect": "tsx scripts/github-app-sync-live-preflight-collect.ts",
    "github:issues:completion-audit": "tsx scripts/github-issues-completion-audit.ts",
    "test:architecture:fitness": "tsx scripts/check-architecture-fitness.ts",
    "test:parallel-worktree:fitness": "tsx scripts/check-parallel-worktree-fitness.ts",
    "test:performance:fitness": "tsx scripts/check-performance-fitness.ts && vitest run tests/performance-fitness.test.ts",
    "test:oss:ownership": "vitest run tests/oss-ownership.test.ts",
    "test:smoke:capabilities": "tsx scripts/feature-capability-report.ts",
    "test:smoke:observability": "tsx scripts/observability-smoke.ts",
    "test:smoke:observability-export": "tsx scripts/observability-export-smoke.ts",
    "test:smoke:deployment": "tsx scripts/deployment-smoke.ts",
    "test:smoke:deployment-async": "tsx scripts/deployment-async-canary.ts",
    "test:smoke:github-app-sync": "tsx scripts/deployment-github-app-sync-canary.ts",
    "test:smoke:deployment-confidence": "tsx scripts/deployment-confidence.ts",
    "cloudflare:provider-evidence": "tsx scripts/cloudflare-provider-evidence.ts",
    "test:load:observability": "tsx scripts/observability-load.ts",
    "test:failure:observability": "tsx scripts/observability-failure-injection.ts",
    "telemetry:rollout-gate": "tsx scripts/observability-rollout-gate.ts",
    "remediation:evidence-map": "tsx scripts/remediation-evidence-map.ts",
    "remediation:dashboard": "tsx scripts/aos-remediation-dashboard.ts --include-git-snapshot",
    "remediation:verify": "tsx scripts/aos-remediation-dashboard.ts --verify-issue-query --include-git-snapshot",
    "start:web:prod": "tsx scripts/start-web.ts",
    "cf:check-size": "tsx scripts/check-cloudflare-bundle-size.ts",
    "start:worker:prod": "tsx scripts/start-worker.ts",
    "worker:start": "npm run start -w @agentic/worker",
    "worker:once": "npm run start:worker:prod -- --once",
    "docs:render": "node scripts/render-docs.mjs",
    "docs:validate": "node scripts/validate-docs.mjs",
    "docs:build": "npm run docs:render && npm run docs:validate",
    "worktree:setup": "tsx scripts/setup-parallel-worktrees.ts",
    "worktree:status": "tsx scripts/worktree-status.ts",
    "worktree:cleanup": "tsx scripts/cleanup-parallel-worktrees.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.105.0",
    "@opennextjs/cloudflare": "1.19.11",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^173.0.0",
    "jszip": "^3.10.1",
    "next": "^16.2.9",
    "openai": "^6.44.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "8.5.12",
    "esbuild": "0.28.1",
    "form-data": "4.0.6",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "4.104.0"
  }
}
