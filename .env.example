# Agentic local development environment template.
# Copy to .env.local or source the values in your shell before starting the app.

# Required before sharing the dashboard/API with anyone else.
# AGENTIC_ACCESS_KEY=replace-this-with-a-long-random-secret

# Instance owner bootstrap. Set these for any persistent shared or production
# install so the runtime is owned by the installer, not a baked-in project user.
# AGENTIC_BOOTSTRAP_USER_ID=owner
# AGENTIC_BOOTSTRAP_DISPLAY_NAME=Instance Owner
# AGENTIC_DEFAULT_TIMEZONE=UTC

# Disposable local-only fallback. Do not enable in shared or production environments.
# AGENTIC_ENABLE_LOCAL_DEV_KEY=true

# Required in production for OAuth redirects, share links, and other externally
# visible absolute URLs.
# AGENTIC_PUBLIC_BASE_URL=https://agentic.example.com

# Leave DATABASE_URL unset for the fastest file-backed local run.
# Set it for Postgres parity and production-like validation.
# DATABASE_URL=postgres://agentic:agentic@localhost:5432/agentic

# Optional: store local file-backed runtime data outside the default .agentic paths.
# AGENTIC_RUNTIME_STORE_PATH=.agentic/runtime-store.json
# AGENTIC_NOTES_PATH=.agentic/notes

# Optional: use shared auth state in development when DATABASE_URL is configured.
# AGENTIC_SHARED_AUTH_STATE=true
# AGENTIC_REQUIRE_SHARED_AUTH_STATE=true

# Production-only unless explicitly approved for a single-instance deployment.
# AGENTIC_ALLOW_PROCESS_LOCAL_AUTH_STATE=true

# Only set behind a trusted reverse proxy that overwrites the configured
# client-IP header at the edge.
# AGENTIC_TRUST_PROXY_HEADERS=true
# AGENTIC_PROXY_HEADER_OVERWRITE_CONFIRMED=true
# AGENTIC_TRUSTED_CLIENT_IP_HEADER=x-forwarded-for

# Production telemetry exports require HTTPS and an explicit allowed-host list.
# AGENTIC_TELEMETRY_EXPORT_URL=https://telemetry.example.com/ingest
# AGENTIC_TELEMETRY_ALLOWED_HOSTS=telemetry.example.com

# Google integrations. Configure all three together or leave all unset.
# GOOGLE_CLIENT_ID=replace-with-google-client-id
# GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# GOOGLE_REFRESH_TOKEN=replace-with-google-refresh-token

# Provider credential encryption for storing OAuth/provider credentials.
# AGENTIC_PROVIDER_SECRET_KEY=replace-with-at-least-32-random-characters
# AGENTIC_PROVIDER_SECRET_KEY_VERSION=2026-05-13

# Provider-backed staging deploy command. Arguments are JSON because the command
# is executed without a shell and the binary is checked against a command allowlist.
# AGENTIC_STAGING_DEPLOY_BIN=node
# AGENTIC_STAGING_DEPLOY_ARGS_JSON=["scripts/provider-deploy.mjs","--environment","staging"]
# AGENTIC_STAGING_DEPLOY_TIMEOUT_MS=1200000

# Worker tuning. Defaults are safe for local development.
# AGENTIC_WORKER_POLL_INTERVAL_MS=1000
# AGENTIC_WORKER_LEASE_MS=30000
# AGENTIC_WORKER_MAX_RUNNING_PER_KIND=2
# AGENTIC_WORKER_MAX_RUNNING_PER_USER=4
# AGENTIC_WORKER_MAX_RUNNING_PER_CONCURRENCY_KEY=1
# AGENTIC_WORKER_RETRY_JITTER_RATIO=0.1
